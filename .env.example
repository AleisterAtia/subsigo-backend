# ============================================
# SubsiGo Backend - Environment Configuration
# Salin file ini menjadi .env lalu isi nilainya.
# ============================================

# Server
APP_PORT=8080
APP_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require

# JWT
JWT_SECRET=
JWT_EXPIRE_HOURS=24
