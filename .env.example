# ============================================
# SubsiGo Backend - Environment Configuration
# Salin file ini menjadi .env lalu isi nilainya.
# Di Vercel: isi nilai-nilai ini di dashboard (Project Settings > Environment Variables),
# JANGAN commit file .env.
# ============================================

# Server (hanya dipakai saat dev lokal `go run ./cmd/api`; di Vercel diabaikan)
APP_PORT=8080
APP_ENV=development

# Database (Neon PostgreSQL)
# PENTING utk serverless: gunakan connection string "Pooled" dari Neon
# (host-nya berakhiran "-pooler", mis. ...-pooler.neon.tech) agar koneksi tidak cepat habis.
DATABASE_URL=postgresql://<user>:<password>@<host>-pooler.neon.tech/<dbname>?sslmode=require

# JWT
JWT_SECRET=
JWT_EXPIRE_HOURS=24

# CORS — origin dashboard admin (Next.js). "*" untuk dev.
# Produksi: isi domain spesifik, mis. https://admin-sitepat.vercel.app
CORS_ALLOW_ORIGINS=*

# Connection pool (jaga kecil untuk serverless). Opsional — punya default.
DB_MAX_OPEN_CONNS=5
DB_MAX_IDLE_CONNS=2
